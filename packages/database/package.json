{
  "name": "@joho-erp/database",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "prisma generate || echo 'Using existing stub types'",
    "type-check": "tsc --noEmit",
    "seed": "tsx src/seed.ts",
    "db:reset-transactional": "tsx src/scripts/reset-transactional-data.ts",
    "db:seed-customers": "tsx src/scripts/seed-customers.ts",
    "db:seed-orders": "tsx src/scripts/seed-orders.ts",
    "db:seed-topside-orders": "tsx src/scripts/seed-topside-orders.ts",
    "backfill:coords": "tsx src/scripts/backfill-customer-coordinates.ts",
    "backfill:coords:apply": "tsx src/scripts/backfill-customer-coordinates.ts --apply",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "prisma:format": "prisma format"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "dotenv": "^17.2.3",
    "prisma": "^6.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
