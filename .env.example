# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/joho-erp?retryWrites=true&w=majority

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/en/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/en/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/en/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/en/dashboard
# Clerk Webhook Secret (for syncing invitation metadata to users)
# Get this from Clerk Dashboard -> Webhooks -> Your Endpoint -> Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...
# Customer portal Clerk secret key (admin portal only - for creating invitations in customer portal's Clerk)
# In dev with a shared Clerk instance, this can equal CLERK_SECRET_KEY
CUSTOMER_PORTAL_CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CUSTOMER_PORTAL_URL=http://localhost:3000

# Resend Email Service
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@johofoods.com
RESEND_ADMIN_EMAIL=admin@johofoods.com

# Twilio SMS Service (for order reminders)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+61400000000

# Cron Job Configuration
# Base URL for internal cron job API calls (REQUIRED)
CRON_BASE_URL=http://127.0.0.1:3001
CRON_SECRET=your_cron_secret_here

# Xero Integration
# Enable/disable Xero integration (set to 'false' to disable, defaults to 'true')
XERO_INTEGRATION_ENABLED=true
XERO_CLIENT_ID=your_client_id
XERO_CLIENT_SECRET=your_client_secret
XERO_REDIRECT_URI=https://admin.johofoods.com/api/xero/auth-callback
XERO_SCOPES=accounting.transactions accounting.contacts
# Optional: Encryption key for secure token storage (64-char hex string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
XERO_TOKEN_ENCRYPTION_KEY=

# Xero webhook signing key — issued by Xero Developer Portal when registering
# the webhook URL (https://<admin-portal>/api/xero/webhooks). Subscribe to the
# INVOICE event category. Required for the AR balance sync.
XERO_WEBHOOK_SIGNING_KEY=
# Informational only — actual URL is /api/xero/webhooks on the admin portal.
XERO_WEBHOOK_URL=
# Default schedule for the nightly balance reconciler (Vercel cron syntax).
XERO_BALANCE_RECONCILE_CRON=0 3 * * *
# Phase 3 cutover flag — when true, calculateAvailableCredit uses
# arBalance.outstandingCents (not the legacy "sum of pre-invoice orders")
# to compute available credit. Leave false until accountant has signed off.
XERO_AR_CREDIT_ENFORCEMENT=false

# Mapbox (for delivery tracking maps)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Cloudflare R2 Storage (S3-compatible)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=joho-erp-uploads
R2_PUBLIC_URL=https://your-r2-public-domain.com

# Application
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development
